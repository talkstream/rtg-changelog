---
import { localePath } from '../i18n/index.ts';
import type { Lang } from '@rtg/shared';

interface Props {
  lang: Lang;
  prevDate?: string;
  nextDate?: string;
}

const { lang, prevDate, nextDate } = Astro.props;
---
{(prevDate || nextDate) && (
  <nav class="pagination" aria-label="Digest dates" style="display:flex;justify-content:space-between;padding:1.5rem 0;font-size:.875rem">
    {nextDate
      ? <a href={localePath(lang, `/${nextDate}`)}>← {nextDate}</a>
      : <span></span>
    }
    {prevDate
      ? <a href={localePath(lang, `/${prevDate}`)}>{prevDate} →</a>
      : <span></span>
    }
  </nav>
)}
