---
import SeriesBadge from './SeriesBadge.astro';
import { t, localePath, formatDate } from '../i18n/index.ts';
import type { Lang } from '@rtg/shared';
import type { IssueView } from '../lib/d1.ts';

interface Props {
  issue: IssueView;
  lang: Lang;
}

const { issue, lang } = Astro.props;
const formattedDate = formatDate(issue.publishedDate, lang);
const issueUrl = localePath(lang, `/issue/${issue.id}`);
---
<article class="issue-card">
  <a href={issueUrl} class="issue-card-link">
    <div class="issue-card-header">
      <time datetime={issue.publishedDate}>{formattedDate}</time>
      <SeriesBadge series={issue.series} lang={lang} />
    </div>
    <div class="issue-card-body">
      <h3 class="issue-card-title">
        {t(lang, 'issue.vol')} {issue.volume} · {t(lang, 'issue.sec')} {issue.section}
      </h3>
      <span class="issue-card-count">
        {issue.documentCount} {t(lang, 'issue.documents')}
      </span>
    </div>
    <span class="issue-card-action">{t(lang, 'issue.viewAll')} &rarr;</span>
  </a>
</article>
