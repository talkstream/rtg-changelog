---
import { t, localePath } from '../i18n/index.ts';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Lang } from '@rtg/shared';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
---
<header class="site-header" role="banner">
  <div class="container">
    <a href={localePath(lang, '/')} class="site-logo">rtg.center</a>
    <nav class="site-nav" aria-label="Main navigation">
      <a href={localePath(lang, '/archive')}>{t(lang, 'nav.archive')}</a>
      <a href={localePath(lang, '/about')}>{t(lang, 'nav.about')}</a>
      <LanguageSwitcher lang={lang} currentPath={currentPath} />
    </nav>
  </div>
</header>
