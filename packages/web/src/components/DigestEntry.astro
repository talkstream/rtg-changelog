---
import SeriesBadge from './SeriesBadge.astro';
import { t } from '../i18n/index.ts';
import type { Lang } from '@rtg/shared';
import type { DigestEntryView } from '../lib/d1.ts';

interface Props {
  entry: DigestEntryView;
  lang: Lang;
}

const { entry, lang } = Astro.props;
const hasHighRelevance = entry.relevanceScore && entry.relevanceScore >= 3;
const relevanceLabel = entry.relevanceScore ? t(lang, `relevance.${entry.relevanceScore}`) : null;
---
<article class="entry" data-series={entry.series}>
  <div class="entry-meta">
    <SeriesBadge series={entry.series} lang={lang} />
    {hasHighRelevance && relevanceLabel && (
      <span class={`relevance relevance-${entry.relevanceScore}`}>
        {relevanceLabel}
      </span>
    )}
    {entry.relevanceTags.length > 0 && (
      <span class="tags">
        {entry.relevanceTags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </span>
    )}
  </div>

  <h3 class="entry-title" lang={lang}>
    {entry.title}
  </h3>

  {lang !== 'th' && (
    <p class="entry-title-th" lang="th">
      {entry.titleTh}
    </p>
  )}

  {entry.summary && (
    <div class="entry-summary">
      <strong>{t(lang, 'digest.whatThisMeans')}:</strong> {entry.summary}
    </div>
  )}

  <footer class="entry-footer">
    <span>
      {t(lang, 'digest.vol')} {entry.volume} · {t(lang, 'digest.sec')} {entry.section}
      {entry.page && <> · {t(lang, 'digest.page')} {entry.page}</>}
    </span>
    {entry.pdfUrl && (
      <a href={entry.pdfUrl} rel="noopener" target="_blank" hreflang="th">
        {t(lang, 'digest.viewPdf')} ↗
        <span class="sr-only"> (opens in new tab, Thai)</span>
      </a>
    )}
  </footer>
</article>
