---
import Base from '../../layouts/Base.astro';
import DateSection from '../../components/DateSection.astro';
import Pagination from '../../components/Pagination.astro';
import { getLangFromUrl, formatDate } from '../../i18n/index.ts';
import { getDigestEntries, getAllDigestDates } from '../../lib/d1.ts';
import type { Lang } from '@rtg/shared';
import { env } from 'cloudflare:workers';

const lang = getLangFromUrl(Astro.url) as Lang;
const { date } = Astro.params;

if (!date || !/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return Astro.redirect(`/${lang}/`, 302);
}

const db = env.DB;

const entries = await getDigestEntries(db, date, lang);
if (entries.length === 0) {
  return new Response(null, { status: 404 });
}

// Get prev/next dates for pagination
const allDates = await getAllDigestDates(db);
const dateList = allDates.map((d) => d.date);
const idx = dateList.indexOf(date);
const prevDate = idx > 0 ? dateList[idx - 1] : undefined;
const nextDate = idx < dateList.length - 1 ? dateList[idx + 1] : undefined;

const title = formatDate(date, lang);
---
<Base title={title}>
  <DateSection date={date} entries={entries} lang={lang} />
  <Pagination lang={lang} prevDate={prevDate} nextDate={nextDate} />
</Base>
