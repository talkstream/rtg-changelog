---
import Base from '../../layouts/Base.astro';
import DocumentView from '../../components/DocumentView.astro';
import { t, getLangFromUrl, localePath, formatDate } from '../../i18n/index.ts';
import { getDocumentsByDate, getLatestDigestDates } from '../../lib/d1.ts';
import type { Lang } from '@rtg/shared';
import { env } from 'cloudflare:workers';

const lang = getLangFromUrl(Astro.url) as Lang;
const date = Astro.params.date || '';

// Validate YYYY-MM-DD format
if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return new Response(null, { status: 404 });
}

const db = env.DB;

const documents = await getDocumentsByDate(db, date, lang);
if (documents.length === 0) {
  return new Response(null, { status: 404 });
}

// Group documents by series
const seriesOrder = ['A', 'B', 'C', 'D'];
const grouped = new Map<string, typeof documents>();
for (const doc of documents) {
  const series = doc.series ?? 'D';
  const existing = grouped.get(series) ?? [];
  existing.push(doc);
  grouped.set(series, existing);
}

// Determine prev/next dates for navigation
const allDates = await getLatestDigestDates(db, 1000);
const dateStrings = allDates.map((d) => d.date);
const currentIndex = dateStrings.indexOf(date);
const prevDate = currentIndex >= 0 && currentIndex < dateStrings.length - 1
  ? dateStrings[currentIndex + 1]
  : null;
const nextDate = currentIndex > 0
  ? dateStrings[currentIndex - 1]
  : null;

const formattedDate = formatDate(date, lang);
const pageTitle = `${t(lang, 'digest.title')} — ${formattedDate}`;
---
<Base title={pageTitle}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href={localePath(lang, '/')}>&larr; {t(lang, 'digest.backToHome')}</a>
  </nav>

  <header class="digest-header">
    <h1 class="page-title">
      <time datetime={date}>{formattedDate}</time>
    </h1>
    <p class="page-subtitle">
      {documents.length} {t(lang, 'digest.documents')}
    </p>
  </header>

  {/* Prev/next navigation */}
  <nav class="digest-nav" aria-label="Date navigation">
    {prevDate ? (
      <a href={localePath(lang, `/${prevDate}`)} class="digest-nav-link">
        &larr; {t(lang, 'digest.prev')}
      </a>
    ) : (
      <span class="digest-nav-disabled">&larr; {t(lang, 'digest.prev')}</span>
    )}
    {nextDate ? (
      <a href={localePath(lang, `/${nextDate}`)} class="digest-nav-link">
        {t(lang, 'digest.next')} &rarr;
      </a>
    ) : (
      <span class="digest-nav-disabled">{t(lang, 'digest.next')} &rarr;</span>
    )}
  </nav>

  {/* Documents grouped by series */}
  {seriesOrder.map((series) => {
    const docs = grouped.get(series);
    if (!docs || docs.length === 0) return null;
    return (
      <section class="series-group">
        <h2 class="series-heading">
          {t(lang, `series.${series}`)}
          <span class="entry-count">{docs.length} {t(lang, 'digest.seriesCount')}</span>
        </h2>
        <div class="issue-documents">
          {docs.map((doc) => (
            <DocumentView doc={doc} lang={lang} standalone={false} />
          ))}
        </div>
      </section>
    );
  })}

  {/* Bottom navigation */}
  <nav class="digest-nav digest-nav-bottom" aria-label="Date navigation">
    {prevDate ? (
      <a href={localePath(lang, `/${prevDate}`)} class="digest-nav-link">
        &larr; {t(lang, 'digest.prev')}
      </a>
    ) : (
      <span class="digest-nav-disabled">&larr; {t(lang, 'digest.prev')}</span>
    )}
    {nextDate ? (
      <a href={localePath(lang, `/${nextDate}`)} class="digest-nav-link">
        {t(lang, 'digest.next')} &rarr;
      </a>
    ) : (
      <span class="digest-nav-disabled">{t(lang, 'digest.next')} &rarr;</span>
    )}
  </nav>
</Base>
