---
import Base from '../../../layouts/Base.astro';
import DocumentView from '../../../components/DocumentView.astro';
import { t, getLangFromUrl, localePath, formatDate } from '../../../i18n/index.ts';
import { getDocumentById } from '../../../lib/d1.ts';
import type { Lang } from '@rtg/shared';
import { env } from 'cloudflare:workers';

const lang = getLangFromUrl(Astro.url) as Lang;
const id = decodeURIComponent(Astro.params.id || '');

if (!id) {
  return Astro.redirect(`/${lang}/`, 302);
}

const db = env.DB;

const doc = await getDocumentById(db, id, lang);
if (!doc) {
  return new Response(null, { status: 404 });
}

const pageTitle = doc.title;
const pageDesc = doc.summary || doc.title;
---
<Base title={pageTitle} description={pageDesc}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    {doc.publishedDate ? (
      <a href={localePath(lang, `/${doc.publishedDate}`)}>
        &larr; {t(lang, 'issue.backToIssue')} &middot; {formatDate(doc.publishedDate, lang)}
      </a>
    ) : (
      <a href={localePath(lang, '/')}>
        &larr; {t(lang, 'digest.backToHome')}
      </a>
    )}
  </nav>

  <DocumentView doc={doc} lang={lang} standalone={true} />
</Base>
