---
import Base from '../../layouts/Base.astro';
import IssueCard from '../../components/IssueCard.astro';
import { t, getLangFromUrl } from '../../i18n/index.ts';
import { getAllIssues } from '../../lib/d1.ts';
import type { Lang } from '@rtg/shared';
import { env } from 'cloudflare:workers';

const lang = getLangFromUrl(Astro.url) as Lang;
const db = env.DB;

const issues = await getAllIssues(db);

// Group issues by date for display
const grouped = new Map<string, typeof issues>();
for (const issue of issues) {
  const existing = grouped.get(issue.publishedDate) ?? [];
  existing.push(issue);
  grouped.set(issue.publishedDate, existing);
}
---
<Base title={t(lang, 'archive.title')}>
  <h1 class="page-title">{t(lang, 'archive.title')}</h1>
  <p class="page-subtitle">{t(lang, 'archive.allDates')}</p>

  {issues.length === 0 ? (
    <div class="no-content">
      <p>{t(lang, 'digest.noEntries')}</p>
    </div>
  ) : (
    <div class="archive-grouped">
      {[...grouped.entries()].map(([date, dateIssues]) => (
        <section class="archive-date-group">
          <h2 class="archive-date-heading">
            <time datetime={date}>
              {new Date(date + 'T00:00:00').toLocaleDateString(
                lang === 'th' ? 'th-TH' : lang === 'ru' ? 'ru-RU' : 'en-US',
                { year: 'numeric', month: 'long', day: 'numeric' }
              )}
            </time>
          </h2>
          <div class="issue-grid">
            {dateIssues.map((issue) => (
              <IssueCard issue={issue} lang={lang} />
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</Base>
