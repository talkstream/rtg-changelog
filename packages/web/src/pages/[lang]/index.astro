---
import Base from '../../layouts/Base.astro';
import IssueCard from '../../components/IssueCard.astro';
import { t, getLangFromUrl, localePath } from '../../i18n/index.ts';
import { getLatestIssues } from '../../lib/d1.ts';
import type { Lang } from '@rtg/shared';
import { env } from 'cloudflare:workers';

const lang = getLangFromUrl(Astro.url) as Lang;
const db = env.DB;

const issues = await getLatestIssues(db, 10);
---
<Base>
  <h1 class="page-title">{t(lang, 'site.subtitle')}</h1>
  <p class="page-subtitle">{t(lang, 'site.description')}</p>

  {issues.length === 0 ? (
    <div class="no-content">
      <p>{t(lang, 'digest.noEntries')}</p>
    </div>
  ) : (
    <div class="issue-grid">
      {issues.map((issue) => (
        <IssueCard issue={issue} lang={lang} />
      ))}
    </div>
  )}

  {issues.length > 0 && (
    <nav class="home-nav">
      <a href={localePath(lang, '/archive')}>{t(lang, 'nav.archive')} &rarr;</a>
    </nav>
  )}
</Base>
